# Boulder Companion — environment variables
# Copy this file to .env and fill in your values, then run docker compose up

# MongoDB connection string
# Default points to the MongoDB container defined in docker-compose.yml.
# Replace with your own URI (e.g. MongoDB Atlas) to use an external database instead.
BOULDER_COMPANION_MONGODB_URI=mongodb://mongodb:27017/boulder_companion

# GitHub OAuth2 app credentials
# Create an app at https://github.com/settings/developers
# Set the callback URL in your GitHub OAuth app to:
#   Local: http://localhost:8080/login/oauth2/code/github
#   Prod:  https://yourdomain.com/login/oauth2/code/github
BOULDER_COMPANION_GITHUB_CLIENT_ID=your_github_client_id
BOULDER_COMPANION_GITHUB_CLIENT_SECRET=your_github_client_secret

# Spring profile (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# Frontend URL (used by backend for CORS)
APP_FRONTEND_URL=http://localhost:5173
